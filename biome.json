{
  "$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "**",
      "!.omx",
      "!.vite",
      "!src/renderer/.vite",
      "!coverage",
      "!dist",
      "!node_modules",
      "!out"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "suspicious": {
        "noExplicitAny": "error"
      },
      "style": {
        "useImportType": "error"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always"
    }
  }
}
